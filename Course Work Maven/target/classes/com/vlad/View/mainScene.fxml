<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.canvas.Canvas?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Slider?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="438.0" prefWidth="782.0" xmlns="http://javafx.com/javafx/24.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.vlad.Controllers.mainSceneController">
   <children>
      <Canvas fx:id="canvas" height="350.0" layoutX="441.0" layoutY="20.0" width="379.0" />
      <Button fx:id="startButton" layoutX="62.0" layoutY="195.0" mnemonicParsing="false" onAction="#startDrawing" prefHeight="24.0" prefWidth="106.0" text="Почати" />
      <Button fx:id="clearButton" layoutX="190.0" layoutY="247.0" mnemonicParsing="false" onAction="#clearCanvas" prefHeight="24.0" prefWidth="106.0" text="Очистити" />
      <Button fx:id="stopButton" layoutX="190.0" layoutY="195.0" mnemonicParsing="false" onAction="#stopDrawing" prefWidth="105.0" text="Зупинити" />
      <Slider fx:id="speedSlider" blockIncrement="1.0" layoutX="59.0" layoutY="163.0" min="1.0" value="50.0" />
      <Label layoutX="59.0" layoutY="120.0" text="Швидкість" />
      <Label layoutX="59.0" layoutY="70.0" text="Кількість точок" />
      <Label layoutX="450.0" layoutY="382.0" text="Кількість намальованих точок" />
      <TextArea fx:id="countDots" layoutX="182.0" layoutY="59.0" prefHeight="38.0" prefWidth="95.0" />
      <Label fx:id="countPaintedDots" layoutX="689.0" layoutY="382.0" prefHeight="16.0" prefWidth="61.0" text="0" />
      <Label fx:id="errorUnderZeroLabel" layoutX="190.0" layoutY="284.0" text="Будь ласка введіть число більше нуля" textFill="RED" visible="false" />
      <Label fx:id="errorNotNumberLabel" layoutX="189.0" layoutY="284.0" text="Будь ласка введіть число" textFill="RED" visible="false" />
      <Button fx:id="continueButton" layoutX="64.0" layoutY="247.0" mnemonicParsing="false" onAction="#startDrawing" prefHeight="24.0" prefWidth="106.0" text="Продовжити" />
   </children>
</AnchorPane>
